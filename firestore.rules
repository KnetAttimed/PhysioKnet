rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
       allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for user progress
    match /users/{userId}/progress/{docId} {
      // Users can only read and write their own progress
      allow read: if isOwner(userId);
      
      allow update, create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['learnedTopics'])
        && request.resource.data.learnedTopics is list;
      
      allow delete: if isOwner(userId);
    }
  }
}
